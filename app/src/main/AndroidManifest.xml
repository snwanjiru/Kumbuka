<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Required for all Spring Boot API calls and Firebase FCM -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!--
        android:name=".KumbukaApplication" belongs on <application>, NOT on <activity>.
        This is what tells Android to use our custom Application class so Hilt
        can initialise its dependency graph before anything else runs.
        Previously this was incorrectly placed on the <activity> tag.
    -->
    <application
        android:name=".KumbukaApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Kumbuka">

        <!--
            The one and only Activity in this single-Activity architecture.
            android:name=".MainActivity" — was previously ".KumbukaApplication" by mistake.
            android:exported="true" is required because it handles the LAUNCHER intent.

            The deep-link intent-filter for Firebase email sign-in has been REMOVED.
            Firebase Auth is no longer used — Spring Boot handles authentication.
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Kumbuka">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            FCM MessagingService — PLACEHOLDER.
            The service class (MyFirebaseMessagingService.kt) does not exist yet.
            This block is commented out to prevent a build error.
            Uncomment and create the class when FCM notifications are implemented
            in a later stage.

        <service
            android:name=".MyFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
        -->

    </application>

</manifest>